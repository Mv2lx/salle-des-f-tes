# ============================================================================
# HOTEL EL FARES — ERP Réception & Événements
# Copy this file to .env (and .env.local for local overrides) and fill in
# real values. Never commit your actual .env file.
# ============================================================================

# --- Database ---------------------------------------------------------------
# Path to the SQLite database file, used by both the app (src/db/index.ts)
# and drizzle-kit (drizzle.config.ts). The parent folder is created
# automatically if it doesn't exist yet.
DATABASE_PATH=./data/hotel.db

# --- Authentication -----------------------------------------------------------
# Secret used to sign session tokens (HMAC-SHA256). Must be at least 16
# characters; use a long random string in production, e.g.:
#   openssl rand -base64 48
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# Password assigned to the demo admin/reception/comptable accounts the first
# time POST /api/seed runs (only used if the users table is empty). Change
# this — and the seeded users' passwords — before going to production.
SEED_DEFAULT_PASSWORD=test1234

# --- Runtime ------------------------------------------------------------------
# Set automatically by most hosting platforms; only needed locally if you
# want to force production behavior (secure cookies, etc.).
# NODE_ENV=development
